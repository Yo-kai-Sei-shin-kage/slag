// Example: Local Arrays
//
//
//
//
//
//
function main() {
    local int[] values = {10, 25, 42, 99, 7};   // fixed-size array
    local int len = values.len;                 // .len returns count

    println(values[0]);                       // index access (zero-based)
    println(values[2]);                       // prints 42
    println(len);                             // prints 5

    return;
}
