// Example: Keyboard Input
global int x = 200;                    // use globals for event handlers

function main() {
    window.open(400, 300, "Press W/A/S/D");

    on key_down(int key) {             // called when key pressed
        if (key == 87) { x = $(($x - 10)); }  // W = 87
        if (key == 83) { x = $(($x + 10)); }  // S = 83
    }

    while (window.is_open()) {
        println(x);                    // show current x value
        window.flush();
    }

    return;
}
