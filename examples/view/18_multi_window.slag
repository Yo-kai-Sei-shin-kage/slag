// Example: Multi-Window  (two windows from one binary via threads + TLS)
function red_window() {
    window.open(300, 200, "Window 1 - Red");
    while (window.is_open()) {
        window.flush();
    }
}

function blue_window() {
    window.open(300, 200, "Window 2 - Blue");
    while (window.is_open()) {
        window.flush();
    }
}

function main() {
    thread { red_window(); }
    thread { blue_window(); }
    sync {}
    return int 0;
}