// Example: Variables and Types
//
//
//
//
//
//
function main() {
    local int x = 100;          // 64-bit signed integer
    local int count = 42;       // another integer
    local float pi = 3.14159;   // 64-bit IEEE 754 double
    local bool active = true;   // boolean (true/false)
    local str name = "Slag";    // immutable string (ptr+len)

    println(x);               // print integer to console
    println(count);
    println(pi);              // print float to console
    println(name);            // print string to console

    return;                   // void return
}
