function main() {
    var int[5] nums = {10, 20, 30, 40, 50};

    println("nums.len:");
    println(nums.len);

    var int i = 0;
    while (i < nums.len) {
        println(nums[i]);
        i = $(($i + 1));
    }

    nums[2] = 999;
    println("after update, nums[2]:");
    println(nums[2]);

    var int total = 0;
    var int j = 0;
    while (j < nums.len) {
        total = $(($total + nums[j]));
        j = $(($j + 1));
    }
    println("sum:");
    println(total);

    var float[3] vals = {1.5, 2.5, 3.0};
    println("vals[1]:");
    println(vals[1]);

    return;
}
