// Orbital motion from config
// orbit.txt: center_x, center_y, radius, w, h, r, g, b, speed

// Sin lookup table (10 entries for 0-90 degrees, scaled by 1000)
global int[] sin90 = {0, 174, 342, 500, 643, 766, 866, 940, 985, 1000};

function get_sin(int angle) {
    // angle is 0-35 (36 steps = 360 degrees)
    // Quadrant 0: 0-8 (0-90)
    // Quadrant 1: 9-17 (90-180)
    // Quadrant 2: 18-26 (180-270)
    // Quadrant 3: 27-35 (270-360)

    var int quad = $(($angle / 9));
    var int idx = $(($angle - $quad * 9));

    var int val = 0;
    if (quad == 0) {
        val = sin90[idx];
    }
    if (quad == 1) {
        val = sin90[$((9 - $idx))];
    }
    if (quad == 2) {
        val = $((0 - sin90[$idx]));
    }
    if (quad == 3) {
        val = $((0 - sin90[$((9 - $idx))]));
    }
    return int val;
}

function get_cos(int angle) {
    var int shifted = $(($angle + 9));
    if (shifted >= 36) {
        shifted = $(($shifted - 36));
    }
    return int get_sin(shifted);
}

function parse_int(int ptr, int start, int end) {
    var int val = 0;
    var int i = start;
    while (i < end) {
        var int byte = mem.peek8(ptr, i);
        if (byte >= 48) {
            if (byte <= 57) {
                val = $(($val * 10 + $byte - 48));
            }
        }
        i = $(($i + 1));
    }
    return int val;
}

function main() {
    window.open(640, 480, "Orbital Motion");

    var str config = readfile("orbit.txt");
    var int ptr = config;

    // Parse values
    var int[] v = {0,0,0,0,0,0,0,0,0};
    var int idx = 0;
    var int line_start = 0;
    var int pos = 0;
    var int done = 0;

    while (done == 0) {
        var int byte = mem.peek8(ptr, pos);
        if (byte == 10) {
            if (pos > line_start) {
                v[idx] = parse_int(ptr, line_start, pos);
                idx = $(($idx + 1));
            }
            line_start = $(($pos + 1));
        }
        if (byte == 0) {
            if (pos > line_start) {
                v[idx] = parse_int(ptr, line_start, pos);
            }
            done = 1;
        }
        pos = $(($pos + 1));
        if (pos > 500) {
            done = 1;
        }
    }

    var int cx = v[0];
    var int cy = v[1];
    var int radius = v[2];
    var int w = v[3];
    var int h = v[4];
    var int r = v[5];
    var int g = v[6];
    var int b = v[7];
    var int speed = v[8];

    var int angle = 0;
    var int frame = 0;

    while (window.is_open()) {
        // Clear
        fill_triangle(0, 0, 640, 0, 640, 480, 0, 0, 0);
        fill_triangle(0, 0, 640, 480, 0, 480, 0, 0, 0);

        // Get sin and cos using lookup functions
        var int sinVal = get_sin(angle);
        var int cosVal = get_cos(angle);

        // Calculate position (scale down by 1000)
        var int x = $(($cx + $radius * $cosVal / 1000 - $w / 2));
        var int y = $(($cy + $radius * $sinVal / 1000 - $h / 2));

        // Draw square
        var int x2 = $(($x + $w));
        var int y2 = $(($y + $h));
        fill_triangle(x, y, x2, y, x2, y2, r, g, b);
        fill_triangle(x, y, x2, y2, x, y2, r, g, b);

        // Draw center point
        fill_triangle($(($cx - 5)), $(($cy - 5)), $(($cx + 5)), $(($cy - 5)), $(($cx + 5)), $(($cy + 5)), 100, 100, 100);
        fill_triangle($(($cx - 5)), $(($cy - 5)), $(($cx + 5)), $(($cy + 5)), $(($cx - 5)), $(($cy + 5)), 100, 100, 100);

        // Update angle every 2 frames for smoother motion
        frame = $(($frame + 1));
        if (frame >= 2) {
            frame = 0;
            angle = $(($angle + $speed));
            if (angle >= 36) {
                angle = $(($angle - 36));
            }
        }

        window.flush();
    }

    return int 0;
}
