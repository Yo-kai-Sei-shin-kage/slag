function main() {
    window.open(800, 600, "Slag Window");
    var int x = 0;
    var int y = 0;
    while (window.open) {
        pixel(x, y, 255, 0, 0);
        x = $(($x + 1));
        if (x == 800) {
            x = 0;
            y = $(($y + 1));
        }
        window.flush();
    }
    return;
}
