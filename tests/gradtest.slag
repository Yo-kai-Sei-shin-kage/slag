function main() {
    window.open(320, 240, "Gradient Test");

    on key_down(int key) {
        if (key == 27) {
            window.close();
        }
    }

    fill_triangle_gradient(
        160, 20,  255, 0, 0,
        300, 220, 0, 255, 0,
        20, 220,  0, 0, 255);

    window.flush();

    while (window.is_open()) {
        window.flush();
    }

    return;
}
