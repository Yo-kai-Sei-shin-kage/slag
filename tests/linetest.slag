function abs_int(int v) {
    if (v < 0) {
        var int neg = $((0 - $v));
        return int neg;
    }
    return int v;
}

function sign_int(int v) {
    if (v > 0) {
        return int 1;
    }
    if (v < 0) {
        return int -1;
    }
    return int 0;
}

function draw_line(int x0, int y0, int x1, int y1, int r, int g, int b) {
    var int dx = abs_int($(($x1 - $x0)));
    var int dy = abs_int($(($y1 - $y0)));
    var int sx = sign_int($(($x1 - $x0)));
    var int sy = sign_int($(($y1 - $y0)));
    var int err = $(($dx - $dy));

    var int x = x0;
    var int y = y0;
    var int running = 1;

    while (running == 1) {
        pixel(x, y, r, g, b);

        if (x == x1) {
            if (y == y1) {
                running = 0;
            }
        }

        if (running == 1) {
            var int e2 = $((2 * $err));
            if (e2 > $((0 - $dy))) {
                err = $(($err - $dy));
                x = $(($x + $sx));
            }
            if (e2 < $dx) {
                err = $(($err + $dx));
                y = $(($y + $sy));
            }
        }
    }
    return;
}

function main() {
    window.open(320, 240, "Line Test");

    on key_down(int key) {
        if (key == 27) {
            window.close();
        }
    }

    draw_line(20, 20, 300, 220, 255, 255, 255);
    draw_line(20, 220, 300, 20, 0, 255, 0);
    draw_line(160, 20, 160, 220, 255, 0, 0);
    draw_line(20, 120, 300, 120, 0, 0, 255);

    window.flush();

    while (window.is_open()) {
        window.flush();
    }

    return;
}
