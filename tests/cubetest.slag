function abs_int(int v) {
    if (v < 0) {
        var int neg = $((0 - $v));
        return int neg;
    }
    return int v;
}

function sign_int(int v) {
    if (v > 0) {
        return int 1;
    }
    if (v < 0) {
        return int -1;
    }
    return int 0;
}

function draw_line(int x0, int y0, int x1, int y1, int r, int g, int b) {
    var int dx = abs_int($(($x1 - $x0)));
    var int dy = abs_int($(($y1 - $y0)));
    var int sx = sign_int($(($x1 - $x0)));
    var int sy = sign_int($(($y1 - $y0)));
    var int err = $(($dx - $dy));

    var int x = x0;
    var int y = y0;
    var int running = 1;

    while (running == 1) {
        pixel(x, y, r, g, b);

        if (x == x1) {
            if (y == y1) {
                running = 0;
            }
        }

        if (running == 1) {
            var int e2 = $((2 * $err));
            if (e2 > $((0 - $dy))) {
                err = $(($err - $dy));
                x = $(($x + $sx));
            }
            if (e2 < $dx) {
                err = $(($err + $dx));
                y = $(($y + $sy));
            }
        }
    }
    return;
}

function to_screen_x(float x, float z) {
    var float d = 4.0;
    var float scale = 100.0;
    var float zd = $(($z + $d));
    var float proj = $(($x * $scale));
    proj = $(($proj / $zd));
    var float sx = $((160.0 + $proj));
    var int result = sx;
    return int result;
}

function to_screen_y(float y, float z) {
    var float d = 4.0;
    var float scale = 100.0;
    var float zd = $(($z + $d));
    var float proj = $(($y * $scale));
    proj = $(($proj / $zd));
    var float sy = $((120.0 - $proj));
    var int result = sy;
    return int result;
}

function main() {
    window.open(320, 240, "Cube Test");

    on key_down(int key) {
        if (key == 27) {
            window.close();
        }
    }

    var int x0 = to_screen_x(-1.0, -1.0);
    var int y0 = to_screen_y(-1.0, -1.0);

    var int x1 = to_screen_x(1.0, -1.0);
    var int y1 = to_screen_y(-1.0, -1.0);

    var int x2 = to_screen_x(1.0, -1.0);
    var int y2 = to_screen_y(1.0, -1.0);

    var int x3 = to_screen_x(-1.0, -1.0);
    var int y3 = to_screen_y(1.0, -1.0);

    var int x4 = to_screen_x(-1.0, 1.0);
    var int y4 = to_screen_y(-1.0, 1.0);

    var int x5 = to_screen_x(1.0, 1.0);
    var int y5 = to_screen_y(-1.0, 1.0);

    var int x6 = to_screen_x(1.0, 1.0);
    var int y6 = to_screen_y(1.0, 1.0);

    var int x7 = to_screen_x(-1.0, 1.0);
    var int y7 = to_screen_y(1.0, 1.0);

    println("vertices computed");

    draw_line(x0, y0, x1, y1, 255, 0, 0);
    draw_line(x1, y1, x2, y2, 255, 0, 0);
    draw_line(x2, y2, x3, y3, 255, 0, 0);
    draw_line(x3, y3, x0, y0, 255, 0, 0);

    draw_line(x4, y4, x5, y5, 0, 255, 0);
    draw_line(x5, y5, x6, y6, 0, 255, 0);
    draw_line(x6, y6, x7, y7, 0, 255, 0);
    draw_line(x7, y7, x4, y4, 0, 255, 0);

    draw_line(x0, y0, x4, y4, 0, 0, 255);
    draw_line(x1, y1, x5, y5, 0, 0, 255);
    draw_line(x2, y2, x6, y6, 0, 0, 255);
    draw_line(x3, y3, x7, y7, 0, 0, 255);

    window.flush();

    while (window.is_open()) {
        window.flush();
    }

    return;
}
