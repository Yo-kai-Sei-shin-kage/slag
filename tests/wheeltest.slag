function main() {
    window.open(320, 240, "Wheel/Middle Test");

    on key_down(int key) {
        if (key == 27) {
            window.close();
        }
    }

    on mouse_down(int button, int mx, int my) {
        if (button == 2) {
            pixel(mx, my, 255, 0, 255);
        }
    }

    on mouse_wheel(int delta) {
        println(delta);
    }

    while (window.is_open()) {
        window.flush();
    }

    return;
}
