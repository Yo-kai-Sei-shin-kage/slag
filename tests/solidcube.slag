function draw_cube_faces(
    int x0, int y0, int x1, int y1, int x2, int y2, int x3, int y3,
    int x4, int y4, int x5, int y5, int x6, int y6, int x7, int y7,
    float b_front, float b_back, float b_left, float b_right, float b_top, float b_bottom)
{
    // front (z=-1) - red
    fill_triangle(x0, y0, x1, y1, x2, y2, shade_channel(200, b_front), shade_channel(30, b_front), shade_channel(30, b_front));
    fill_triangle(x0, y0, x2, y2, x3, y3, shade_channel(200, b_front), shade_channel(30, b_front), shade_channel(30, b_front));

    // back (z=1) - green
    fill_triangle(x4, y4, x5, y5, x6, y6, shade_channel(30, b_back), shade_channel(180, b_back), shade_channel(30, b_back));
    fill_triangle(x4, y4, x6, y6, x7, y7, shade_channel(30, b_back), shade_channel(180, b_back), shade_channel(30, b_back));

    // left (x=-1) - blue
    fill_triangle(x0, y0, x3, y3, x7, y7, shade_channel(30, b_left), shade_channel(30, b_left), shade_channel(200, b_left));
    fill_triangle(x0, y0, x7, y7, x4, y4, shade_channel(30, b_left), shade_channel(30, b_left), shade_channel(200, b_left));

    // right (x=1) - yellow
    fill_triangle(x1, y1, x2, y2, x6, y6, shade_channel(200, b_right), shade_channel(200, b_right), shade_channel(30, b_right));
    fill_triangle(x1, y1, x6, y6, x5, y5, shade_channel(200, b_right), shade_channel(200, b_right), shade_channel(30, b_right));

    // top (y=-1) - magenta
    fill_triangle(x0, y0, x1, y1, x5, y5, shade_channel(200, b_top), shade_channel(30, b_top), shade_channel(200, b_top));
    fill_triangle(x0, y0, x5, y5, x4, y4, shade_channel(200, b_top), shade_channel(30, b_top), shade_channel(200, b_top));

    // bottom (y=1) - cyan
    fill_triangle(x3, y3, x2, y2, x6, y6, shade_channel(30, b_bottom), shade_channel(200, b_bottom), shade_channel(200, b_bottom));
    fill_triangle(x3, y3, x6, y6, x7, y7, shade_channel(30, b_bottom), shade_channel(200, b_bottom), shade_channel(200, b_bottom));
    return;
}

function draw_cube_faces_color(
    int x0, int y0, int x1, int y1, int x2, int y2, int x3, int y3,
    int x4, int y4, int x5, int y5, int x6, int y6, int x7, int y7,
    int r, int g, int b)
{
    fill_triangle(x0, y0, x1, y1, x2, y2, r, g, b);
    fill_triangle(x0, y0, x2, y2, x3, y3, r, g, b);
    fill_triangle(x4, y4, x5, y5, x6, y6, r, g, b);
    fill_triangle(x4, y4, x6, y6, x7, y7, r, g, b);
    fill_triangle(x0, y0, x3, y3, x7, y7, r, g, b);
    fill_triangle(x0, y0, x7, y7, x4, y4, r, g, b);
    fill_triangle(x1, y1, x2, y2, x6, y6, r, g, b);
    fill_triangle(x1, y1, x6, y6, x5, y5, r, g, b);
    fill_triangle(x0, y0, x1, y1, x5, y5, r, g, b);
    fill_triangle(x0, y0, x5, y5, x4, y4, r, g, b);
    fill_triangle(x3, y3, x2, y2, x6, y6, r, g, b);
    fill_triangle(x3, y3, x6, y6, x7, y7, r, g, b);
    return;
}

function to_screen_x(float x, float z) {
    var float d = 4.0;
    var float scale = 200.0;
    var float zd = $(($z + $d));
    var float proj = $(($x * $scale));
    proj = $(($proj / $zd));
    var float sx = $((320.0 + $proj));
    var int result = sx;
    return int result;
}

function to_screen_y(float y, float z) {
    var float d = 4.0;
    var float scale = 200.0;
    var float zd = $(($z + $d));
    var float proj = $(($y * $scale));
    proj = $(($proj / $zd));
    var float sy = $((400.0 - $proj));
    var int result = sy;
    return int result;
}

// cross product (a x b) component helpers, for edge vectors a=(ax,ay,az), b=(bx,by,bz)
function cross_x(float ay, float az, float by, float bz) {
    var float r = $((($ay * $bz) - ($az * $by)));
    return float r;
}
function cross_y(float ax, float az, float bx, float bz) {
    var float r = $((($az * $bx) - ($ax * $bz)));
    return float r;
}
function cross_z(float ax, float ay, float bx, float by) {
    var float r = $((($ax * $by) - ($ay * $bx)));
    return float r;
}

// dot product of two 3D vectors
function dot3(float ax, float ay, float az, float bx, float by, float bz) {
    var float d = $((($ax * $bx) + ($ay * $by)));
    d = $(($d + ($az * $bz)));
    return float d;
}

// scale a 0-255 color channel by brightness (0.0-1.0+), clamp to [0,255]
function shade_channel(int base, float brightness) {
    var float scaled = $(($base * $brightness));
    var int result = scaled;
    if (result > 255) { result = 255; }
    if (result < 0) { result = 0; }
    return int result;
}

// compute brightness in [0.3, 1.0] from a face normal and fixed light dir (0,0,-1)
// (light pointing toward the viewer/camera)
function face_brightness(float nx, float ny, float nz) {
    var float lx = 0.0;
    var float ly = 0.0;
    var float lz = -1.0;
    var float d = dot3(nx, ny, nz, lx, ly, lz);
    // normalize roughly: cube edge length 2, cross product magnitude ~4
    var float t = $(($d / 4.0));
    if (t < 0.0) { t = 0.0; }
    if (t > 1.0) { t = 1.0; }
    var float brightness = $((0.3 + (0.7 * $t)));
    return float brightness;
}

function main() {
    window.open(640, 800, "Solid Cube");

    on key_down(int key) {
        if (key == 27) {
            window.close();
        }
    }

    var float cosy = 0.99862953;
    var float siny = 0.05233596;
    var float cosx = 0.99756406;
    var float sinx = 0.06975647;

    var float vx0 = -1.0; var float vy0 = -1.0; var float vz0 = -1.0;
    var float vx1 =  1.0; var float vy1 = -1.0; var float vz1 = -1.0;
    var float vx2 =  1.0; var float vy2 =  1.0; var float vz2 = -1.0;
    var float vx3 = -1.0; var float vy3 =  1.0; var float vz3 = -1.0;
    var float vx4 = -1.0; var float vy4 = -1.0; var float vz4 =  1.0;
    var float vx5 =  1.0; var float vy5 = -1.0; var float vz5 =  1.0;
    var float vx6 =  1.0; var float vy6 =  1.0; var float vz6 =  1.0;
    var float vx7 = -1.0; var float vy7 =  1.0; var float vz7 =  1.0;

    var int px0 = 0; var int py0 = 0;
    var int px1 = 0; var int py1 = 0;
    var int px2 = 0; var int py2 = 0;
    var int px3 = 0; var int py3 = 0;
    var int px4 = 0; var int py4 = 0;
    var int px5 = 0; var int py5 = 0;
    var int px6 = 0; var int py6 = 0;
    var int px7 = 0; var int py7 = 0;

    var int first_frame = 1;
    var int last_time = time.now_ms();
    var int frame_count = 0;

    while (window.is_open()) {
        var float tx0 = $(($vx0 * $cosy)); var float tz0 = $(($vx0 * $siny));
        tx0 = $(($tx0 + ($vz0 * $siny)));
        tz0 = $((($vz0 * $cosy) - $tz0));

        var float tx1 = $(($vx1 * $cosy)); var float tz1 = $(($vx1 * $siny));
        tx1 = $(($tx1 + ($vz1 * $siny)));
        tz1 = $((($vz1 * $cosy) - $tz1));

        var float tx2 = $(($vx2 * $cosy)); var float tz2 = $(($vx2 * $siny));
        tx2 = $(($tx2 + ($vz2 * $siny)));
        tz2 = $((($vz2 * $cosy) - $tz2));

        var float tx3 = $(($vx3 * $cosy)); var float tz3 = $(($vx3 * $siny));
        tx3 = $(($tx3 + ($vz3 * $siny)));
        tz3 = $((($vz3 * $cosy) - $tz3));

        var float tx4 = $(($vx4 * $cosy)); var float tz4 = $(($vx4 * $siny));
        tx4 = $(($tx4 + ($vz4 * $siny)));
        tz4 = $((($vz4 * $cosy) - $tz4));

        var float tx5 = $(($vx5 * $cosy)); var float tz5 = $(($vx5 * $siny));
        tx5 = $(($tx5 + ($vz5 * $siny)));
        tz5 = $((($vz5 * $cosy) - $tz5));

        var float tx6 = $(($vx6 * $cosy)); var float tz6 = $(($vx6 * $siny));
        tx6 = $(($tx6 + ($vz6 * $siny)));
        tz6 = $((($vz6 * $cosy) - $tz6));

        var float tx7 = $(($vx7 * $cosy)); var float tz7 = $(($vx7 * $siny));
        tx7 = $(($tx7 + ($vz7 * $siny)));
        tz7 = $((($vz7 * $cosy) - $tz7));

        var float ty0 = $(($vy0 * $cosx)); var float fz0 = $(($vy0 * $sinx));
        ty0 = $(($ty0 - ($tz0 * $sinx)));
        fz0 = $(($fz0 + ($tz0 * $cosx)));

        var float ty1 = $(($vy1 * $cosx)); var float fz1 = $(($vy1 * $sinx));
        ty1 = $(($ty1 - ($tz1 * $sinx)));
        fz1 = $(($fz1 + ($tz1 * $cosx)));

        var float ty2 = $(($vy2 * $cosx)); var float fz2 = $(($vy2 * $sinx));
        ty2 = $(($ty2 - ($tz2 * $sinx)));
        fz2 = $(($fz2 + ($tz2 * $cosx)));

        var float ty3 = $(($vy3 * $cosx)); var float fz3 = $(($vy3 * $sinx));
        ty3 = $(($ty3 - ($tz3 * $sinx)));
        fz3 = $(($fz3 + ($tz3 * $cosx)));

        var float ty4 = $(($vy4 * $cosx)); var float fz4 = $(($vy4 * $sinx));
        ty4 = $(($ty4 - ($tz4 * $sinx)));
        fz4 = $(($fz4 + ($tz4 * $cosx)));

        var float ty5 = $(($vy5 * $cosx)); var float fz5 = $(($vy5 * $sinx));
        ty5 = $(($ty5 - ($tz5 * $sinx)));
        fz5 = $(($fz5 + ($tz5 * $cosx)));

        var float ty6 = $(($vy6 * $cosx)); var float fz6 = $(($vy6 * $sinx));
        ty6 = $(($ty6 - ($tz6 * $sinx)));
        fz6 = $(($fz6 + ($tz6 * $cosx)));

        var float ty7 = $(($vy7 * $cosx)); var float fz7 = $(($vy7 * $sinx));
        ty7 = $(($ty7 - ($tz7 * $sinx)));
        fz7 = $(($fz7 + ($tz7 * $cosx)));

        vx0 = tx0; vy0 = ty0; vz0 = fz0;
        vx1 = tx1; vy1 = ty1; vz1 = fz1;
        vx2 = tx2; vy2 = ty2; vz2 = fz2;
        vx3 = tx3; vy3 = ty3; vz3 = fz3;
        vx4 = tx4; vy4 = ty4; vz4 = fz4;
        vx5 = tx5; vy5 = ty5; vz5 = fz5;
        vx6 = tx6; vy6 = ty6; vz6 = fz6;
        vx7 = tx7; vy7 = ty7; vz7 = fz7;

        var int sx0 = to_screen_x(vx0, vz0); var int sy0 = to_screen_y(vy0, vz0);
        var int sx1 = to_screen_x(vx1, vz1); var int sy1 = to_screen_y(vy1, vz1);
        var int sx2 = to_screen_x(vx2, vz2); var int sy2 = to_screen_y(vy2, vz2);
        var int sx3 = to_screen_x(vx3, vz3); var int sy3 = to_screen_y(vy3, vz3);
        var int sx4 = to_screen_x(vx4, vz4); var int sy4 = to_screen_y(vy4, vz4);
        var int sx5 = to_screen_x(vx5, vz5); var int sy5 = to_screen_y(vy5, vz5);
        var int sx6 = to_screen_x(vx6, vz6); var int sy6 = to_screen_y(vy6, vz6);
        var int sx7 = to_screen_x(vx7, vz7); var int sy7 = to_screen_y(vy7, vz7);

        // --- compute per-face brightness from face normals (using rotated 3D coords) ---
        // front face: vertices 0,1,2  edges (v1-v0),(v2-v0)
        var float ax = $(($vx1 - $vx0)); var float ay = $(($vy1 - $vy0)); var float az = $(($vz1 - $vz0));
        var float bx = $(($vx2 - $vx0)); var float by = $(($vy2 - $vy0)); var float bz = $(($vz2 - $vz0));
        var float n_front_x = cross_x(ay, az, by, bz);
        var float n_front_y = cross_y(ax, az, bx, bz);
        var float n_front_z = cross_z(ax, ay, bx, by);
        var float b_front = face_brightness(n_front_x, n_front_y, n_front_z);

        // back face: vertices 4,5,6
        ax = $(($vx5 - $vx4)); ay = $(($vy5 - $vy4)); az = $(($vz5 - $vz4));
        bx = $(($vx6 - $vx4)); by = $(($vy6 - $vy4)); bz = $(($vz6 - $vz4));
        var float n_back_x = cross_x(ay, az, by, bz);
        var float n_back_y = cross_y(ax, az, bx, bz);
        var float n_back_z = cross_z(ax, ay, bx, by);
        var float b_back = face_brightness(n_back_x, n_back_y, n_back_z);

        // left face: vertices 0,3,7
        ax = $(($vx3 - $vx0)); ay = $(($vy3 - $vy0)); az = $(($vz3 - $vz0));
        bx = $(($vx7 - $vx0)); by = $(($vy7 - $vy0)); bz = $(($vz7 - $vz0));
        var float n_left_x = cross_x(ay, az, by, bz);
        var float n_left_y = cross_y(ax, az, bx, bz);
        var float n_left_z = cross_z(ax, ay, bx, by);
        var float b_left = face_brightness(n_left_x, n_left_y, n_left_z);

        // right face: vertices 1,2,6
        ax = $(($vx2 - $vx1)); ay = $(($vy2 - $vy1)); az = $(($vz2 - $vz1));
        bx = $(($vx6 - $vx1)); by = $(($vy6 - $vy1)); bz = $(($vz6 - $vz1));
        var float n_right_x = cross_x(ay, az, by, bz);
        var float n_right_y = cross_y(ax, az, bx, bz);
        var float n_right_z = cross_z(ax, ay, bx, by);
        var float b_right = face_brightness(n_right_x, n_right_y, n_right_z);

        // top face: vertices 0,1,5
        ax = $(($vx1 - $vx0)); ay = $(($vy1 - $vy0)); az = $(($vz1 - $vz0));
        bx = $(($vx5 - $vx0)); by = $(($vy5 - $vy0)); bz = $(($vz5 - $vz0));
        var float n_top_x = cross_x(ay, az, by, bz);
        var float n_top_y = cross_y(ax, az, bx, bz);
        var float n_top_z = cross_z(ax, ay, bx, by);
        var float b_top = face_brightness(n_top_x, n_top_y, n_top_z);

        // bottom face: vertices 3,2,6
        ax = $(($vx2 - $vx3)); ay = $(($vy2 - $vy3)); az = $(($vz2 - $vz3));
        bx = $(($vx6 - $vx3)); by = $(($vy6 - $vy3)); bz = $(($vz6 - $vz3));
        var float n_bottom_x = cross_x(ay, az, by, bz);
        var float n_bottom_y = cross_y(ax, az, bx, bz);
        var float n_bottom_z = cross_z(ax, ay, bx, by);
        var float b_bottom = face_brightness(n_bottom_x, n_bottom_y, n_bottom_z);

        // erase previous frame by filling its faces black
        if (first_frame == 0) {
            draw_cube_faces_color(
                px0, py0, px1, py1, px2, py2, px3, py3,
                px4, py4, px5, py5, px6, py6, px7, py7,
                0, 0, 0);
        }
        first_frame = 0;

        draw_cube_faces(
            sx0, sy0, sx1, sy1, sx2, sy2, sx3, sy3,
            sx4, sy4, sx5, sy5, sx6, sy6, sx7, sy7,
            b_front, b_back, b_left, b_right, b_top, b_bottom);

        px0 = sx0; py0 = sy0; px1 = sx1; py1 = sy1;
        px2 = sx2; py2 = sy2; px3 = sx3; py3 = sy3;
        px4 = sx4; py4 = sy4; px5 = sx5; py5 = sy5;
        px6 = sx6; py6 = sy6; px7 = sx7; py7 = sy7;

        window.flush();

        frame_count = $(($frame_count + 1));
        var int now = time.now_ms();
        var int elapsed = $(($now - $last_time));
        if (elapsed > 1000) {
            println("fps:");
            println(frame_count);
            frame_count = 0;
            last_time = now;
        }
    }

    return;
}
