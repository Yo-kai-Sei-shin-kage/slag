function main() {
    window.open(320, 240, "Triangle Test");

    on key_down(int key) {
        if (key == 27) {
            window.close();
        }
    }

    fill_triangle(50, 50, 270, 60, 160, 220, 255, 0, 0);
    fill_triangle(20, 200, 100, 20, 180, 200, 0, 255, 0);

    window.flush();

    while (window.is_open()) {
        window.flush();
    }

    return;
}
