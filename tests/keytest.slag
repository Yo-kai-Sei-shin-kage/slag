function main() {
    window.open(320, 240, "Key Test");

    on key_down(int key) {
        if (key == 27) {
            window.close();
        }
    }

    var int x = 0;
    while (x < 320) {
        pixel(x, 100, 0, 255, 0);
        x = $(($x + 1));
    }
    window.flush();

    while (window.is_open()) {
        window.flush();
    }

    return;
}
